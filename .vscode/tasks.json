{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Configure Project",
            "type": "shell",
            "command": "cmake -B build -DCMAKE_BUILD_TYPE=Debug .",
            "group": "build"
        },
        {
            "label": "Build Project",
            "type": "shell",
            "command": "cmake --build build",
            "problemMatcher": "$gcc",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Deploy Project",
            "type": "shell",
            "command": "$(cygpath $Qt6_ROOT)/bin/windeployqt.exe build/AVDL2.exe",
            "group": "build",
            "dependsOn": "Build Project"
        }
    ]
}